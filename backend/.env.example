# ──────────────────────────────────────────
# 이 파일을 복사해 .env로 저장 후 값을 채우세요.
# .env는 .gitignore에 포함되어 있습니다.
# ──────────────────────────────────────────

# Application
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-secret-key

# PostgreSQL
POSTGRES_PASSWORD=devpassword

# RabbitMQ
RABBITMQ_PASSWORD=devpassword

# Storage
STORAGE_PATH=/app/storage

# (자동 조합 — 수정 불필요)
# DATABASE_URL=postgresql+asyncpg://ctdp:{POSTGRES_PASSWORD}@db:5432/chip_test_db
# RABBITMQ_URL=amqp://ctdp:{RABBITMQ_PASSWORD}@rabbitmq:5672/chip_test
# REDIS_URL=redis://redis:6379/0
